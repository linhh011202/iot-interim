graph TB
    Title["Consensus Mechanism Comparison for Blockchain-IoT"]

    subgraph POW_G["Proof of Work - PoW"]
        POW_E["Energy: Very High"]
        POW_T["Throughput: Low ~7 tps"]
        POW_F["Fault Tolerance: 51% attack"]
        POW_S["Scalability: Low"]
        POW_D["Decentralization: High"]
        POW_IoT["IoT Suitability: Incompatible"]
    end

    subgraph POS_G["Proof of Stake - PoS"]
        POS_E["Energy: Low"]
        POS_T["Throughput: Medium ~30 tps"]
        POS_F["Fault Tolerance: Nothing-at-stake risk"]
        POS_S["Scalability: Medium"]
        POS_D["Decentralization: Medium"]
        POS_IoT["IoT Suitability: Partial - NFT modules"]
    end

    subgraph POT_G["Proof of Trust - PoT"]
        POT_E["Energy: Very Low"]
        POT_T["Throughput: High"]
        POT_F["Fault Tolerance: Trust-weighted"]
        POT_S["Scalability: High"]
        POT_D["Decentralization: Medium"]
        POT_IoT["IoT Suitability: Optimized"]
    end

    subgraph BFT_G["Byzantine Fault Tolerance - BFT"]
        BFT_E["Energy: Medium"]
        BFT_T["Throughput: Medium-High"]
        BFT_F["Fault Tolerance: Up to 1/3 nodes"]
        BFT_S["Scalability: Low-Medium"]
        BFT_D["Decentralization: Low-Medium"]
        BFT_IoT["IoT Suitability: Good for low-trust"]
    end

    subgraph RAFT_G["Raft Consensus"]
        RAFT_E["Energy: Low"]
        RAFT_T["Throughput: High"]
        RAFT_F["Fault Tolerance: Leader election failover"]
        RAFT_S["Scalability: Medium"]
        RAFT_D["Decentralization: Low - leader-based"]
        RAFT_IoT["Best for DCHR administration"]
    end

    Title --> POW_G
    Title --> POS_G
    Title --> POT_G
    Title --> BFT_G
    Title --> RAFT_G

